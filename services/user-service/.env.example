# User Service — Local Development Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it's already in .gitignore.

# ─── Service Identity ──────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=user-service
PORT=3002
LOG_LEVEL=info

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fintech_user:password@localhost:5432/user_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://fintech_user:password@localhost:5672

# ─── Internal Service-to-Service API Key ────────────────────────────────────────
INTERNAL_API_KEY=demo-internal-key

# ─── JWT RS256 Public Key ──────────────────────────────────────────────────────
# Pasteurize the JWT_PUBLIC_KEY from auth-service's .env here.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
< your key >
-----END PUBLIC KEY-----"
