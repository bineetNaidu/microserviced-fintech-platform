{
  "name": "@fintech/api-gateway",
  "version": "1.0.0",
  "description": "Edge proxy and security guard — single entry point for all client traffic",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run clean"
  },
  "dependencies": {
    "@fintech/shared-config": "*",
    "@fintech/shared-errors": "*",
    "@fintech/shared-middleware": "*",
    "@fintech/shared-types": "*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "http-proxy-middleware": "^4.2.0",
    "ioredis": "^5.11.1",
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
