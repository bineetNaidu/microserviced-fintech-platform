# API Gateway — Local Development Environment Variables
# Copy to .env and fill in actual values before running.
# NEVER commit .env to Git — already in .gitignore.

# ─── Service Identity ──────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=api-gateway
PORT=8080
LOG_LEVEL=info

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed client origins.
# For local dev: your frontend's dev server URL.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_pass@localhost:6379

# ─── Upstream Service URLs ─────────────────────────────────────────────────────
# In local dev, these point to localhost + each service's PORT.
# In Kubernetes, these become http://{service-name}:{port} (kube-dns resolved).
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
ACCOUNT_SERVICE_URL=http://localhost:3003
TRANSFER_SERVICE_URL=http://localhost:3004

# ─── JWT RS256 Public Key ──────────────────────────────────────────────────────
# This is the PUBLIC KEY only — not the private key.
# The gateway can VERIFY tokens but cannot SIGN new ones.
# Must match the JWT_PUBLIC_KEY in auth-service's .env.
#
# Generate with:
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat public.pem
#
# Then paste the content here:
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<paste the same public key as auth-service JWT_PUBLIC_KEY>
-----END PUBLIC KEY-----"
