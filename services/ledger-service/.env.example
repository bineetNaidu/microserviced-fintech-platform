# Ledger Service — Local Development Environment Variables example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it's already in .gitignore.

# ─── Service Identity ──────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=ledger-service
PORT=3005
LOG_LEVEL=info

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# DATABASE_URL uses the restricted runtime credentials to block DELETE/UPDATE at the database level.
DATABASE_URL=postgresql://application_runtime_user:change_me_in_production@localhost:5432/ledger_db
# MIGRATION_DATABASE_URL uses owner credentials to run migrations and setup permissions.
MIGRATION_DATABASE_URL=postgresql://fintech_user:change_me_in_production@localhost:5432/ledger_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:change_me_in_production@localhost:6379

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://fintech_user:change_me_in_production@localhost:5672

# ─── Internal Service-to-Service API Key ────────────────────────────────────────
INTERNAL_API_KEY=test-internal-key

# ─── Downstream Services ───────────────────────────────────────────────────────
ACCOUNT_SERVICE_URL=http://localhost:3003
