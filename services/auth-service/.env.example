# Auth Service — Local Development Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it's already in .gitignore.

# ─── Service Identity ──────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=auth-service
PORT=3001
LOG_LEVEL=info

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fintech_user:fintech_pass@localhost:5432/auth_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://fintech_user:fintech_pass@localhost:5672

# ─── JWT RS256 Key Pair ────────────────────────────────────────────────────────
# Generate a key pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Then paste the content here (replace newlines with \n in single-line format,
# or use the multi-line format below for local .env files).
#
# NEVER commit these keys to Git.

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
<paste your private key here>
-----END PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<paste your public key here>
-----END PUBLIC KEY-----"
