# Account Service — Local Development Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it's already in .gitignore.

# ─── Service Identity ──────────────────────────────────────────────────────────
# NODE_ENV control logging verbosity and error detail exposure.
NODE_ENV=development
SERVICE_NAME=account-service
PORT=3003
LOG_LEVEL=info

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Pointing to the isolated account_db instance
DATABASE_URL=postgresql://fintech_user:password@localhost:5432/account_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Pointing to the shared Redis cache instance
REDIS_URL=redis://:password@localhost:6379

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
# AMQP connection URL
RABBITMQ_URL=amqp://fintech_user:password@localhost:5672

# ─── Internal Service-to-Service API Key ────────────────────────────────────────
# Required to authenticate internal API calls (e.g. from transfer-service)
INTERNAL_API_KEY=demo-internal-key

# ─── JWT RS256 Public Key ──────────────────────────────────────────────────────
# Pasteurize the JWT_PUBLIC_KEY from auth-service's .env here.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
< your key >
-----END PUBLIC KEY-----"

# ─── Downstream Upstream Services ──────────────────────────────────────────────
# Endpoint for user-service to perform KYC status verification
USER_SERVICE_URL=http://localhost:3002
