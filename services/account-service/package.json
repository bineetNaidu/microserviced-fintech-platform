{
  "name": "@fintech/account-service",
  "version": "1.0.0",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run clean",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node src/db/migrate.ts"
  },
  "dependencies": {
    "@fintech/shared-config": "*",
    "@fintech/shared-db": "*",
    "@fintech/shared-errors": "*",
    "@fintech/shared-events": "*",
    "@fintech/shared-messaging": "*",
    "@fintech/shared-middleware": "*",
    "@fintech/shared-types": "*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^5.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "ulid": "^2.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
