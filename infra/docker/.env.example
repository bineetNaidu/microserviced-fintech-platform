# ─────────────────────────────────────────────────────────────────────────────
# Docker Infrastructure — Environment Variables
# Copy to .env and fill in your values before running `docker compose up`.
# NEVER commit .env to Git. It is already listed in the root .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=fintech_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=fintech_user
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
