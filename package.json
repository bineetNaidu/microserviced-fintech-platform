{
  "name": "fintech-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade microservices fintech platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build:packages": "npm run build --workspace=@fintech/shared-types && npm run build --workspace=@fintech/shared-errors && npm run build --workspace=@fintech/shared-config && npm run build --workspace=@fintech/shared-events && npm run build --workspace=@fintech/shared-middleware",
    "build:services": "npm run build --workspace=services/* --if-present",
    "build:apps": "npm run build --workspace=apps/* --if-present",
    "build": "npm run build:packages && npm run build:services && npm run build:apps",
    "clean:packages": "rm -rf packages/*/dist",
    "clean:services": "rm -rf services/*/dist",
    "clean": "npm run clean:packages && npm run clean:services",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,js,json,md,yaml,yml}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
